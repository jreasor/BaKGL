{
    "Paths": {
        "Shaders": "",
        "Saves": "",
        "GameData": "game_files/",
        "GraphicsOverrides": "",
        "Assets4k": "assets_4k/"
    },
    "Graphics": {
        "ResolutionScale": 4.0,
        "EnableShadows": true,
        "EnableImGui": false,
        "DrawDistance": 128000,
        "MaxTextureDim": 2048,
        // Task 3.3-B: ceiling on the number of layers a single TextureStore may
        // upload into one GL_TEXTURE_2D_ARRAY (was the hardcoded
        // TextureBuffer::sMaxTextures = 256). 0/unset => 256 (built-in default).
        // Raising it is VRAM-free for stores that don't approach it (allocation is
        // exact-per-store); raise only if a logical sheet legitimately needs >256
        // frames.
        "MaxTextures": 256,
        // Task 3.3-C: opt-in RGBA8 (GL_UNSIGNED_BYTE) texture staging. Default
        // false = legacy GL_FLOAT staging (driver converts floats to RGBA8
        // during upload). The RGBA8 path builds the bytes on the CPU
        // (BuildRgba8Staging) -- 4x smaller staging buffer + bus, no driver
        // float conversion, identical pixels -- but in the Debug build its
        // per-channel scalar quantize regresses the fill ~2.5x (the dominant
        // zone-hitch cost), so it is gated off until a vectorized build or
        // Task 3.3-D's async PBO path makes it a net win. Unit-tested
        // (textureUploadTest); exercised by booting with this set to true.
        "RGBA8Upload": false,
        // Task 3.3-D: opt-in async PBO texture upload. Default false = the C path
        // (synchronous RGBA8 staging -> glTexSubImage3D with a client pointer,
        // which blocks the render thread on the GPU transfer). When true,
        // LoadTexturesGL stages the RGBA8 bytes in a PixelUnpackBuffer and
        // issues glTexSubImage3D(data=nullptr) so the driver enqueues a GPU-side
        // copy and returns immediately. Only the `upload` segment of A's timer
        // split is PBO-acceleratable -- fill (CPU BuildRgba8Staging) and mipmap
        // (glGenerateMipmap) are not -- and a single PBO with no double-buffering
        // still syncs at glGenerateMipmap, so this is an async *foundation* +
        // decoupled staging for a future off-thread fill / double-buffered path,
        // not a zone-hitch fix. Falls back to the C path (RGBA8Upload) when off.
        "AsyncTextureUpload": false,
        // Task 3.2: hero fullscreen backgrounds (BASE names, no extension) get a
        // dedicated one-layer sheet at the substitute's full uncapped resolution.
        // Empty list = today's behavior (all substitutes capped to MaxTextureDim).
        // Increment A lands this inert; Increment B populates it. See ROADMAP §3.2.
        "HeroTextures": [],
        // Task 3.5: anisotropic filtering level for LinearMipmap textures
        // (GL_TEXTURE_MAX_ANISOTROPY_EXT). 0 = off (plain trilinear); >0 clamped
        // to the driver's reported max. Engages where the sample footprint is
        // anisotropic -- oblique terrain/ground in the 3D world (head-on GUI
        // screens and billboarded combat sprites have isotropic footprints, so
        // this is a free no-op there and a quality win on terrain). Default 4.
        "AnisotropicFilter": 4.0,
        // Task 4.4: ON = use original 1993 art (no assets_4k/ substitution); OFF = 4K remaster.
        "OriginalMode": false,
        "DebugDisableFades": false,
        "DebugRenderEncounters": false
    },
    "Audio": {
        // ADLMIDI | OPNMIDI | FluidSynth
        "MidiPlayer": "ADLMIDI",
        "EnableAudio": true,
        "EnableBackgroundSounds": true 
    },
    "Game": {
        "AdvanceTime": true,
        "CombatSpeed": 1.0
    },
    "Logging": {
        "LogToFile": true,
        "LogTime": true,
        "LogColours": true,
        "LogFilePath": "",
        // SPAM | DEBUG | INFO | WARN | ERROR | FATAL
        "LogLevel": "DEBUG",
        "DisabledLoggers": [
            "Compass",
            "DialogStore",
            "LoadEncounter",
            "LoadFixedObjects",
            "LoadSceneIndices",
            "LoadScenes",
            "MeshObjectStore",
            "GameData",
            "Gui::StaticTTM",
            "GuiRenderer",
            "Gui::DialogRunner",
            "Gui::DialogDisplay",
            "Gui::AnimatorStore",
            "TeleportFactory",
            "FMAP_TWN",
            "FMAP",
            "CampData",
            "CreateFileBuffer"
        ]
    }
}
